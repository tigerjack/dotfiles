;; Tracked template for the local Spacemacs theme override.
;; switch_theme.sh copies this to local-themes.el (gitignored) and rewrites
;; the dotspacemacs-themes line in place, so the generated file -- not this
;; template, not init.el -- is what actually changes on every theme switch.
(setq my-dotspacemacs-themes '(spacemacs-light spacemacs-dark))
